# ──────────────────────────────────────────────────────────────────────────────
# Lead-Ops · Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
#
# NEVER commit your .env file — it is gitignored by default.
# ──────────────────────────────────────────────────────────────────────────────

# [Required] Hugging Face API token for model inference
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [Required] Base URL for the LLM inference endpoint
API_BASE_URL=https://api-inference.huggingface.co/models/your-model

# [Required] Tavily search API key for web enrichment
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [Optional] Database connection string (defaults to local SQLite)
DATABASE_URL=sqlite:///lead_ops.db

# [Optional] Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

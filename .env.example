# ──────────────────────────────────────────────────────────────────────────────
# Lead-Ops · Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
#
# NEVER commit your .env file — it is gitignored by default.
# ──────────────────────────────────────────────────────────────────────────────

# ─── LLM Provider Selection ──────────────────────────────────────────────────
# Choose which LLM provider to use: openai | huggingface | gemini
# Default: openai (required for official submission)
LLM_PROVIDER=openai

# ─── OpenAI Configuration (for submission) ──────────────────────────────────
# [Required if LLM_PROVIDER=openai] OpenAI API key
# Get it from: https://platform.openai.com/account/api-keys
# Model will default to: gpt-4o-mini
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── HuggingFace Configuration (for local testing, FREE) ────────────────────
# [Required if LLM_PROVIDER=huggingface] HuggingFace API token
# Get it from: https://huggingface.co/settings/tokens
# Model will default to: mistralai/Mistral-7B-Instruct-v0.2
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Custom LLM Endpoint (optional) ─────────────────────────────────────────
# Override the default API_BASE_URL for your chosen provider
# Leave blank to use provider defaults
# API_BASE_URL=https://your-custom-endpoint.com/v1

# ─── Custom Model Name (optional) ───────────────────────────────────────────
# Override the default model for your chosen provider
# Leave blank to use provider defaults
# MODEL_NAME=your-model-name

# ─── Web Search Integration ─────────────────────────────────────────────────
# [Required] Tavily search API key for web enrichment
# Get it from: https://tavily.com
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Database & Logging (optional) ──────────────────────────────────────────
# Database URL (default: sqlite:///lead_ops.db)
DATABASE_URL=sqlite:///lead_ops.db

# Log level (default: INFO)
LOG_LEVEL=INFO

# [Optional] Database connection string (defaults to local SQLite)
DATABASE_URL=sqlite:///lead_ops.db

# [Optional] Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# [Optional] Override the environment URL for inference.py
# ENV_URL=http://localhost:7860
